<a href="/allTransactions">&larr; 목록으로</a>
<div class="admin-title">
    <h2>
        <%= locals.title %>
    </h2>
    <div class="admin-post-controls">
        <a href="/edit/<%= data._id %>" class="btn">편집</a>
        <form action="/delete/<%= data._id %>?_method=DELETE" method="POST">
            <input type="submit" value="삭제" class="btn-delete btn">
        </form>
    </div>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">구분</span>
        <span class="detail-value">
            <% if (data.type === 'income') { %>
                <span class="badge badge-income">수입</span>
            <% } else { %>
                <span class="badge badge-expense">지출</span>
            <% } %>
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">날짜</span>
        <span class="detail-value"><%= data.date.toISOString().slice(0, 10) %></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">분류</span>
        <span class="detail-value"><%= data.category %></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">금액</span>
        <span class="detail-value <%= data.type === 'income' ? 'amount-income' : 'amount-expense' %>">
            <%= data.type === 'income' ? '+' : '-' %><%= data.amount.toLocaleString() %>원
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">메모</span>
        <span class="detail-value"><%= data.memo ? data.memo : '-' %></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">등록일시</span>
        <span class="detail-value"><%= data.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }) %></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">수정일시</span>
        <span class="detail-value"><%= data.updatedAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }) %></span>
    </div>
</div>
